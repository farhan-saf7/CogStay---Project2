@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Booking History";
    ViewData["Role"] = "Customer";
}

<div style="margin-bottom: 30px;">
    <h1 style="font-family: var(--font-serif); font-size: 32px; color: var(--color-primary-dark);">Your Booking History</h1>
    <p style="color: var(--color-text-muted);">Manage your active, upcoming, and past room reservations with CogStay.</p>
</div>

<!-- History Controls -->
<div class="cogstay-filter-bar">
    <div class="cogstay-filter-group">
        <label class="cogstay-form-label" style="margin-bottom: 2px;">Filter Status</label>
        <select class="cogstay-form-control" style="padding: 8px 12px;">
            <option value="all">All Stays</option>
            <option value="active">Active / Checked In</option>
            <option value="upcoming">Upcoming reservations</option>
            <option value="completed">Completed Stays</option>
            <option value="cancelled">Cancelled</option>
        </select>
    </div>
    
    <div style="margin-left: auto;">
        <span style="font-size: 13px; color: var(--color-text-muted);">Showing 5 historical records</span>
    </div>
</div>

<!-- Booking Table -->
<div class="cogstay-card">
    <div class="cogstay-card-header">
        <h3 class="cogstay-card-title"><i class="fa-solid fa-list"></i> Reservations Catalog</h3>
    </div>
    <div class="cogstay-table-responsive">
        <table class="cogstay-table">
            <thead>
                <tr>
                    <th>Booking ID</th>
                    <th>Room Type</th>
                    <th>Dates of Stay</th>
                    <th>Guests</th>
                    <th>Rate Total</th>
                    <th>Payment</th>
                    <th>Stay Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Active checked in stay -->
                <tr>
                    <td><strong>#CS-9024</strong></td>
                    <td>Room 304 - Penthouse Suite</td>
                    <td>Jun 24 - Jun 28, 2026</td>
                    <td>2</td>
                    <td>₹1,25,440.00</td>
                    <td><span class="cogstay-badge warning">Partial (₹12,000 bal)</span></td>
                    <td><span class="cogstay-badge success">Checked In</span></td>
                    <td>
                        <button class="btn btn-secondary btn-sm"><i class="fa-solid fa-download"></i> Receipt</button>
                    </td>
                </tr>

                <!-- Upcoming stay -->
                <tr>
                    <td><strong>#CS-9288</strong></td>
                    <td>Room 301 - Deluxe Executive</td>
                    <td>Jul 15 - Jul 18, 2026</td>
                    <td>1</td>
                    <td>₹48,384.00</td>
                    <td><span class="cogstay-badge info">Paid</span></td>
                    <td><span class="cogstay-badge info">Confirmed</span></td>
                    <td>
                        <button class="btn btn-secondary btn-sm"><i class="fa-solid fa-download"></i> Receipt</button>
                    </td>
                </tr>

                <!-- Past stay 1 -->
                <tr>
                    <td><strong>#CS-8711</strong></td>
                    <td>Room 201 - Superior King</td>
                    <td>May 10 - May 12, 2026</td>
                    <td>2</td>
                    <td>₹25,088.00</td>
                    <td><span class="cogstay-badge success">Paid</span></td>
                    <td><span class="cogstay-badge success">Completed</span></td>
                    <td>
                        <button class="btn btn-secondary btn-sm"><i class="fa-solid fa-download"></i> Receipt</button>
                    </td>
                </tr>

                <!-- Past stay 2 -->
                <tr>
                    <td><strong>#CS-8430</strong></td>
                    <td>Room 202 - Superior King</td>
                    <td>Mar 04 - Mar 08, 2026</td>
                    <td>2</td>
                    <td>₹48,384.00</td>
                    <td><span class="cogstay-badge success">Paid</span></td>
                    <td><span class="cogstay-badge success">Completed</span></td>
                    <td>
                        <button class="btn btn-secondary btn-sm"><i class="fa-solid fa-download"></i> Receipt</button>
                    </td>
                </tr>

                <!-- Cancelled stay -->
                <tr>
                    <td><strong>#CS-8012</strong></td>
                    <td>Room 302 - Deluxe Executive</td>
                    <td>Jan 12 - Jan 15, 2026</td>
                    <td>2</td>
                    <td>₹49,728.00</td>
                    <td><span class="cogstay-badge danger">Refunded</span></td>
                    <td><span class="cogstay-badge danger">Cancelled</span></td>
                    <td>
                        <button class="btn btn-secondary btn-sm" disabled style="opacity: 0.5;"><i class="fa-solid fa-ban"></i> N/A</button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
