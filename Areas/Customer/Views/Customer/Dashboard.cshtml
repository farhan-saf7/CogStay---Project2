@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Guest Dashboard";
    ViewData["Role"] = "Customer";
}

<div style="margin-bottom: 30px;">
    <h1 style="font-family: var(--font-serif); font-size: 32px; color: var(--color-primary-dark);">Welcome back, Mr. Henderson</h1>
    <p style="color: var(--color-text-muted);">CogStay Guest Portal &bull; Room 304 (Deluxe Suite)</p>
</div>

<!-- Stats Counters -->
<div class="grid-container grid-cols-4" style="margin-bottom: 30px;">
    <div class="cogstay-stat-card customer">
        <div class="cogstay-stat-details">
            <p>Active Stay</p>
            <h3>Room 304</h3>
        </div>
        <div class="cogstay-stat-icon">
            <i class="fa-solid fa-key"></i>
        </div>
    </div>

    <div class="cogstay-stat-card customer">
        <div class="cogstay-stat-details">
            <p>Check-out Date</p>
            <h3>June 28</h3>
        </div>
        <div class="cogstay-stat-icon">
            <i class="fa-solid fa-calendar-days"></i>
        </div>
    </div>

    <div class="cogstay-stat-card customer">
        <div class="cogstay-stat-details">
            <p>Outstanding Bal.</p>
            <h3>₹12,000.00</h3>
        </div>
        <div class="cogstay-stat-icon">
            <i class="fa-solid fa-file-invoice-dollar"></i>
        </div>
    </div>

    <div class="cogstay-stat-card customer">
        <div class="cogstay-stat-details">
            <p>Loyalty Status</p>
            <h3>Gold Class</h3>
        </div>
        <div class="cogstay-stat-icon">
            <i class="fa-solid fa-crown"></i>
        </div>
    </div>
</div>

<div class="booking-checkout-container">
    <!-- Left Column: Current stays & Services -->
    <div>
        <!-- Active Stay details -->
        <div class="cogstay-card">
            <div class="cogstay-card-header">
                <h3 class="cogstay-card-title"><i class="fa-solid fa-circle-info"></i> Your Current Booking Details</h3>
                <span class="cogstay-badge success">Checked In</span>
            </div>
            <div class="cogstay-card-body">
                <div class="grid-container grid-cols-2" style="gap: 15px; margin-bottom: 20px;">
                    <div>
                        <strong style="font-size: 13px; color: var(--color-text-muted); text-transform: uppercase;">Guest Name</strong>
                        <p style="font-size: 15px; font-weight: 600; margin-top: 3px;">John Henderson</p>
                    </div>
                    <div>
                        <strong style="font-size: 13px; color: var(--color-text-muted); text-transform: uppercase;">Room Selection</strong>
                        <p style="font-size: 15px; font-weight: 600; margin-top: 3px;">Room 304 - Penthouse Suite</p>
                    </div>
                    <div>
                        <strong style="font-size: 13px; color: var(--color-text-muted); text-transform: uppercase;">Check-In Date</strong>
                        <p style="font-size: 15px; font-weight: 600; margin-top: 3px;">June 24, 2026</p>
                    </div>
                    <div>
                        <strong style="font-size: 13px; color: var(--color-text-muted); text-transform: uppercase;">Check-Out Date</strong>
                        <p style="font-size: 15px; font-weight: 600; margin-top: 3px;">June 28, 2026</p>
                    </div>
                </div>
                <div style="background-color: #FAF9F6; border: 1px solid var(--color-border); border-radius: var(--border-radius); padding: 15px; display: flex; align-items: center; justify-content: space-between;">
                    <div>
                        <strong style="font-size: 14px; color: var(--color-primary-dark);"><i class="fa-solid fa-concierge-bell"></i> Need Housekeeping assistance?</strong>
                        <p style="font-size: 12px; color: var(--color-text-muted); margin-top: 2px;">Submit emergency cleaning, laundry requests or food delivery details.</p>
                    </div>
                    <a href="/Customer/Customer/Feedback" class="btn btn-primary btn-sm">Request Service</a>
                </div>
            </div>
        </div>

        <!-- Recent activities / Request histories (5-8 rows) -->
        <div class="cogstay-card">
            <div class="cogstay-card-header">
                <h3 class="cogstay-card-title"><i class="fa-solid fa-clock-rotate-left"></i> Recent Guest Requests & Orders</h3>
            </div>
            <div class="cogstay-table-responsive">
                <table class="cogstay-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Request Type</th>
                            <th>Requested For</th>
                            <th>Time Logged</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>#SR-3012</td>
                            <td>Extra Pillows (Cleaning)</td>
                            <td>Room 304</td>
                            <td>Today, 2:10 PM</td>
                            <td><span class="cogstay-badge success">Delivered</span></td>
                        </tr>
                        <tr>
                            <td>#FD-9024</td>
                            <td>Breakfast Waffles (Food)</td>
                            <td>Room 304</td>
                            <td>Today, 8:15 AM</td>
                            <td><span class="cogstay-badge success">Delivered</span></td>
                        </tr>
                        <tr>
                            <td>#LR-1102</td>
                            <td>Suit Dry-Cleaning (Laundry)</td>
                            <td>Room 304</td>
                            <td>Yesterday, 4:30 PM</td>
                            <td><span class="cogstay-badge success">Delivered</span></td>
                        </tr>
                        <tr>
                            <td>#MT-5502</td>
                            <td>AC Thermostat Reset (Maintenance)</td>
                            <td>Room 304</td>
                            <td>June 24, 7:15 PM</td>
                            <td><span class="cogstay-badge success">Resolved</span></td>
                        </tr>
                        <tr>
                            <td>#SR-2980</td>
                            <td>Spa Aromatherapy Soap Set</td>
                            <td>Room 304</td>
                            <td>June 24, 4:00 PM</td>
                            <td><span class="cogstay-badge success">Delivered</span></td>
                        </tr>
                        <tr>
                            <td>#FD-8940</td>
                            <td>Sparkling Water Delivery</td>
                            <td>Room 304</td>
                            <td>June 24, 2:30 PM</td>
                            <td><span class="cogstay-badge success">Delivered</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Right Column: Quick Links & Actions -->
    <div>
        <div class="cogstay-card">
            <div class="cogstay-card-header">
                <h3 class="cogstay-card-title"><i class="fa-solid fa-bolt"></i> Quick Actions</h3>
            </div>
            <div class="cogstay-card-body" style="display: flex; flex-direction: column; gap: 12px;">
                <a href="/Customer/Customer/AvailableRooms" class="btn btn-secondary" style="width: 100%; text-align: left; justify-content: flex-start;">
                    <i class="fa-solid fa-magnifying-glass"></i> Browse Available Rooms
                </a>
                <a href="/Customer/Customer/BookRoom" class="btn btn-secondary" style="width: 100%; text-align: left; justify-content: flex-start;">
                    <i class="fa-solid fa-calendar-check"></i> Make New Reservation
                </a>
                <a href="/Customer/Customer/Payment" class="btn btn-secondary" style="width: 100%; text-align: left; justify-content: flex-start;">
                    <i class="fa-solid fa-credit-card"></i> Pay Outstanding Balance
                </a>
                <a href="/Customer/Customer/Feedback" class="btn btn-secondary" style="width: 100%; text-align: left; justify-content: flex-start;">
                    <i class="fa-solid fa-comment-dots"></i> Leave Hotel Review
                </a>
                <a href="/Customer/Customer/Profile" class="btn btn-secondary" style="width: 100%; text-align: left; justify-content: flex-start;">
                    <i class="fa-solid fa-user-pen"></i> Update Profile Info
                </a>
            </div>
        </div>

        <div class="cogstay-card" style="background-color: var(--color-primary-dark); color: #ffffff; border: none;">
            <div class="cogstay-card-body">
                <h4 style="font-family: var(--font-serif); font-size: 18px; color: var(--color-accent-light); margin-bottom: 10px;">Exclusive Gold Offer</h4>
                <p style="font-size: 13px; color: rgba(255,255,255,0.8); line-height: 1.5; margin-bottom: 15px;">Enjoy 15% off spa therapies and fine-dining room delivery during your stay Henderson.</p>
                <a href="/Customer/Customer/AvailableRooms" class="btn btn-accent btn-sm" style="color: var(--color-primary-dark)">Browse Offers</a>
            </div>
        </div>
    </div>
</div>
