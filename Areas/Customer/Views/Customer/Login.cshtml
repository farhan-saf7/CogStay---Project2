@{
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
    ViewData["Title"] = "Guest Login";
}

<div class="cogstay-login-card">
    <div class="cogstay-login-header">
        <h2 class="cogstay-login-title">Guest Portal Access</h2>
        <p class="cogstay-login-desc">Sign in to book rooms, manage reservations, and order services.</p>
    </div>

    <!-- Login form pointing to Customer Dashboard -->
    <form method="post" action="/Customer/Customer/Dashboard" data-success-message="Login successful! Welcome to CogStay Portal." data-redirect="/Customer/Customer/Dashboard">
        <div class="cogstay-form-group">
            <label class="cogstay-form-label">Email Address</label>
            <input type="email" class="cogstay-form-control" placeholder="guest@example.com" required value="guest@example.com" />
        </div>

        <div class="cogstay-form-group">
            <label class="cogstay-form-label">Password</label>
            <input type="password" class="cogstay-form-control" placeholder="&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;" required value="password123" />
        </div>

        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px;">
            <label style="display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--color-text-muted);">
                <input type="checkbox" checked /> Remember me
            </label>
            <a href="#" style="font-size: 13px; color: var(--color-accent); font-weight: 600;">Forgot Password?</a>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%; padding: 12px;">Sign In</button>
    </form>

    <div style="text-align: center; margin-top: 24px; border-top: 1px solid var(--color-border); padding-top: 20px;">
        <span style="font-size: 13px; color: var(--color-text-muted);">New to CogStay? </span>
        <a href="/Customer/Customer/Profile" style="font-size: 13px; color: var(--color-accent); font-weight: 600;">Create Guest Account</a>
    </div>
</div>
