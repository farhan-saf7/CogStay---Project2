@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Guest Check-Out";
    ViewData["Role"] = "FrontDesk";
}

<div style="margin-bottom: 30px;">
    <h1 style="font-family: var(--font-serif); font-size: 32px; color: var(--color-primary-dark);">CogStay Front Desk Check-Out</h1>
    <p style="color: var(--color-text-muted);">Settle guest bills, add extra mini-bar/laundry charges, and deactivate room key cards.</p>
</div>

<div class="booking-checkout-container">
    <!-- Left Column: Checkout charges form -->
    <div class="cogstay-card">
        <div class="cogstay-card-header">
            <h3 class="cogstay-card-title"><i class="fa-solid fa-file-invoice-dollar"></i> Settle Final Balance</h3>
        </div>
        <div class="cogstay-card-body">
            <form method="post" action="/FrontDesk/FrontDesk/Dashboard" data-success-message="Check-out settled successfully! Room key deactivated and guest checked-out." data-redirect="/FrontDesk/FrontDesk/Dashboard">
                <div class="cogstay-form-group">
                    <label class="cogstay-form-label">Search Room or Guest</label>
                    <div style="display: flex; gap: 10px;">
                        <input type="text" class="cogstay-form-control" placeholder="e.g. Room 304 or John Henderson" value="Room 304" />
                        <button type="button" class="btn btn-secondary" onclick="showToast('Search Completed', 'Guest John Henderson checked-in stay found.', 'success')">Retrieve Stay</button>
                    </div>
                </div>

                <div class="cogstay-form-row">
                    <div class="cogstay-form-group">
                        <label class="cogstay-form-label">Guest Name</label>
                        <input type="text" class="cogstay-form-control" value="John Henderson" readonly />
                    </div>
                    <div class="cogstay-form-group">
                        <label class="cogstay-form-label">Room Number</label>
                        <input type="text" class="cogstay-form-control" value="Room 304 (Suite)" readonly />
                    </div>
                </div>

                <div class="cogstay-form-row">
                    <div class="cogstay-form-group">
                        <label class="cogstay-form-label">Add Mini-Bar Charges (₹)</label>
                        <input type="number" id="checkout-cost-minibar" class="cogstay-form-control" value="3200" min="0" />
                    </div>
                    <div class="cogstay-form-group">
                        <label class="cogstay-form-label">Add Damages / Incidentals (₹)</label>
                        <input type="number" id="checkout-cost-damages" class="cogstay-form-control" value="0" min="0" />
                    </div>
                </div>

                <div style="border-top: 1px solid var(--color-border); padding-top: 20px; display: flex; justify-content: flex-end; gap: 12px;">
                    <a href="/FrontDesk/FrontDesk/Dashboard" class="btn btn-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary" style="background-color: var(--accent-frontdesk);"><i class="fa-solid fa-credit-card"></i> Settle & Check-Out</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Right Column: Final Ledger totals -->
    <div class="cogstay-card">
        <div class="cogstay-card-header">
            <h3 class="cogstay-card-title"><i class="fa-solid fa-receipt"></i> Settle Checkout Quote</h3>
        </div>
        <div class="cogstay-card-body">
            <div class="booking-price-row">
                <span>Room Charges:</span>
                <strong id="checkout-summary-room">₹6,400.00</strong>
            </div>
            <div class="booking-price-row">
                <span>Mini-Bar Order:</span>
                <strong>+₹3,200.00</strong>
            </div>
            <div class="booking-price-row">
                <span>Incidentals:</span>
                <strong>+₹0.00</strong>
            </div>
            <hr style="border: 0; border-top: 1px solid var(--color-border); margin: 15px 0;" />
            <div class="booking-price-total">
                <span>Total Quote Due:</span>
                <strong id="checkout-summary-total">₹9,600.00</strong>
            </div>
        </div>
    </div>
</div>
