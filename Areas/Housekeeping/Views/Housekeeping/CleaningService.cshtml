@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Cleaning Service";
    ViewData["Role"] = "Housekeeping";
}

<div style="margin-bottom: 30px;">
    <h1 style="font-family: var(--font-serif); font-size: 32px; color: var(--color-primary-dark);">Room Cleaning Schedule</h1>
    <p style="color: var(--color-text-muted);">View check-out sheets, log room clean updates, and manage cleanliness compliance.</p>
</div>

<!-- Cleaning Table -->
<div class="cogstay-card">
    <div class="cogstay-card-header">
        <h3 class="cogstay-card-title"><i class="fa-solid fa-bucket"></i> Rooms Housekeeping Logs</h3>
    </div>
    
    <!-- Table filters -->
    <div style="padding: 20px 24px; border-bottom: 1px solid var(--color-border); display: flex; gap: 15px; flex-wrap: wrap;">
        <div class="search-input-wrapper">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" id="admin-table-search" class="cogstay-form-control" placeholder="Search Room Number..." />
        </div>
        <div style="min-width: 150px;">
            <select id="admin-table-filter-status" class="cogstay-form-control">
                <option value="all">All Room States</option>
                <option value="clean">Clean</option>
                <option value="dirty">Dirty</option>
                <option value="cleaning">Cleaning</option>
            </select>
        </div>
    </div>

    <div class="cogstay-table-responsive">
        <table class="cogstay-table">
            <thead>
                <tr>
                    <th>Room No.</th>
                    <th>Category</th>
                    <th>Cleanliness</th>
                    <th>Cleaning Type</th>
                    <th>Assignee</th>
                    <th>Roster Action</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>Room 101</strong></td>
                    <td>Superior King</td>
                    <td><span class="cogstay-badge success">Clean</span></td>
                    <td>Stay-Over Clean</td>
                    <td>Mary Poppins</td>
                    <td>
                        <button class="btn btn-secondary btn-sm" disabled style="opacity: 0.5;">No Action</button>
                    </td>
                </tr>
                <tr>
                    <td><strong>Room 102</strong></td>
                    <td>Superior King</td>
                    <td><span class="cogstay-badge warning">Dirty</span></td>
                    <td>Checkout Clean</td>
                    <td>Mary Poppins</td>
                    <td>
                        <button class="btn btn-primary btn-sm" style="background-color: var(--accent-housekeeping);" onclick="showToast('Success', 'Updated Room 102 status to CLEAN.', 'success')">Mark Clean</button>
                    </td>
                </tr>
                <tr>
                    <td><strong>Room 201</strong></td>
                    <td>Deluxe Executive</td>
                    <td><span class="cogstay-badge success">Clean</span></td>
                    <td>Stay-Over Clean</td>
                    <td>Peter Parker</td>
                    <td>
                        <button class="btn btn-secondary btn-sm" disabled style="opacity: 0.5;">No Action</button>
                    </td>
                </tr>
                <tr>
                    <td><strong>Room 202</strong></td>
                    <td>Deluxe Executive</td>
                    <td><span class="cogstay-badge success">Clean</span></td>
                    <td>Checkout Clean</td>
                    <td>Peter Parker</td>
                    <td>
                        <button class="btn btn-secondary btn-sm" disabled style="opacity: 0.5;">No Action</button>
                    </td>
                </tr>
                <tr>
                    <td><strong>Room 304</strong></td>
                    <td>Penthouse Suite</td>
                    <td><span class="cogstay-badge info">Cleaning</span></td>
                    <td>Checkout Clean</td>
                    <td>Bruce Wayne</td>
                    <td>
                        <button class="btn btn-primary btn-sm" style="background-color: var(--accent-housekeeping);" onclick="showToast('Success', 'Updated Room 304 status to CLEAN.', 'success')">Mark Clean</button>
                    </td>
                </tr>
                <tr>
                    <td><strong>Room 305</strong></td>
                    <td>Penthouse Suite</td>
                    <td><span class="cogstay-badge danger">Dirty</span></td>
                    <td>Deep Clean</td>
                    <td>Bruce Wayne</td>
                    <td>
                        <button class="btn btn-primary btn-sm" style="background-color: var(--accent-housekeeping);" onclick="showToast('Success', 'Cleaning registered.', 'success')">Begin Cleaning</button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
