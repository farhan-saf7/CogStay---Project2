@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Reservations Console";
    ViewData["Role"] = "Manager";
}

<div style="margin-bottom: 30px;">
    <h1 style="font-family: var(--font-serif); font-size: 32px; color: var(--color-primary-dark);">CogStay Reservations Yield</h1>
    <p style="color: var(--color-text-muted);">Monitor overall room bookings density, active stay ratios, and cancellaton metrics.</p>
</div>

<!-- Yield stats -->
<div class="grid-container grid-cols-4" style="margin-bottom: 30px;">
    <div class="cogstay-stat-card manager">
        <div class="cogstay-stat-details">
            <p>Active Checked-In</p>
            <h3>84 stays</h3>
        </div>
        <div class="cogstay-stat-icon">
            <i class="fa-solid fa-person-walking-luggage" style="color: var(--color-primary);"></i>
        </div>
    </div>
    
    <div class="cogstay-stat-card manager">
        <div class="cogstay-stat-details">
            <p>Confirmed Stays</p>
            <h3>112 bookings</h3>
        </div>
        <div class="cogstay-stat-icon">
            <i class="fa-solid fa-circle-check" style="color: var(--color-primary);"></i>
        </div>
    </div>

    <div class="cogstay-stat-card manager">
        <div class="cogstay-stat-details">
            <p>Today Arrivals</p>
            <h3>14 check-ins</h3>
        </div>
        <div class="cogstay-stat-icon">
            <i class="fa-solid fa-passport" style="color: var(--color-primary);"></i>
        </div>
    </div>

    <div class="cogstay-stat-card manager">
        <div class="cogstay-stat-details">
            <p>Cancellations</p>
            <h3>3 this week</h3>
        </div>
        <div class="cogstay-stat-icon">
            <i class="fa-solid fa-rectangle-xmark" style="color: var(--color-primary);"></i>
        </div>
    </div>
</div>

<!-- Table -->
<div class="cogstay-card">
    <div class="cogstay-card-header">
        <h3 class="cogstay-card-title"><i class="fa-solid fa-list"></i> Reservations Database</h3>
    </div>
    <div class="cogstay-table-responsive">
        <table class="cogstay-table">
            <thead>
                <tr>
                    <th>Booking ID</th>
                    <th>Guest</th>
                    <th>Room Allocated</th>
                    <th>Stay Dates</th>
                    <th>Amount Quote</th>
                    <th>Payment</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>#CS-9024</strong></td>
                    <td>John Henderson</td>
                    <td>Room 304 (Suite)</td>
                    <td>Jun 24 - Jun 28, 2026</td>
                    <td>₹1,25,440.00</td>
                    <td><span class="cogstay-badge warning">Partial</span></td>
                    <td><span class="cogstay-badge success">Checked In</span></td>
                </tr>
                <tr>
                    <td><strong>#CS-9288</strong></td>
                    <td>Emily Watson</td>
                    <td>Room 301 (Deluxe)</td>
                    <td>Jul 15 - Jul 18, 2026</td>
                    <td>₹48,384.00</td>
                    <td><span class="cogstay-badge info">Paid</span></td>
                    <td><span class="cogstay-badge info">Confirmed</span></td>
                </tr>
                <tr>
                    <td><strong>#CS-9402</strong></td>
                    <td>Robert Downey</td>
                    <td>Room 201 (Standard)</td>
                    <td>Jul 20 - Jul 25, 2026</td>
                    <td>₹80,640.00</td>
                    <td><span class="cogstay-badge danger">Unpaid</span></td>
                    <td><span class="cogstay-badge warning">Pending</span></td>
                </tr>
                <tr>
                    <td><strong>#CS-8711</strong></td>
                    <td>Albert Einstein</td>
                    <td>Room 201 (Standard)</td>
                    <td>May 10 - May 12, 2026</td>
                    <td>₹25,088.00</td>
                    <td><span class="cogstay-badge success">Paid</span></td>
                    <td><span class="cogstay-badge success">Completed</span></td>
                </tr>
                <tr>
                    <td><strong>#CS-8430</strong></td>
                    <td>Grace Hopper</td>
                    <td>Room 202 (Standard)</td>
                    <td>Mar 04 - Mar 08, 2026</td>
                    <td>₹48,384.00</td>
                    <td><span class="cogstay-badge success">Paid</span></td>
                    <td><span class="cogstay-badge success">Completed</span></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
