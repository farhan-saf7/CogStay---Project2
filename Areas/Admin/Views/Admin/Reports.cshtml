@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Reports";
    ViewData["Role"] = "Admin";
}

<div style="margin-bottom: 30px;">
    <h1 style="font-family: var(--font-serif); font-size: 32px; color: var(--color-primary-dark);">CogStay Reports & Analytics</h1>
    <p style="color: var(--color-text-muted);">Generate financial statements, occupancy records, and housekeeping audit sheets.</p>
</div>

<!-- Financial Stats Summaries -->
<div class="grid-container grid-cols-3" style="margin-bottom: 30px;">
    <div class="cogstay-card">
        <div class="cogstay-card-body" style="text-align: center; padding: 30px 20px;">
            <p style="font-size: 13px; text-transform: uppercase; color: var(--color-text-muted); font-weight: 600; letter-spacing: 0.5px;">Avg Daily Rate (ADR)</p>
            <h2 style="font-size: 36px; font-weight: 700; color: var(--color-primary-dark); margin: 10px 0;">₹14,736.00</h2>
            <span class="cogstay-badge success"><i class="fa-solid fa-arrow-trend-up"></i> +5.4% vs last month</span>
        </div>
    </div>

    <div class="cogstay-card">
        <div class="cogstay-card-body" style="text-align: center; padding: 30px 20px;">
            <p style="font-size: 13px; text-transform: uppercase; color: var(--color-text-muted); font-weight: 600; letter-spacing: 0.5px;">Occupancy Rate</p>
            <h2 style="font-size: 36px; font-weight: 700; color: var(--color-primary-dark); margin: 10px 0;">84.6%</h2>
            <span class="cogstay-badge success"><i class="fa-solid fa-arrow-trend-up"></i> +1.2% vs last month</span>
        </div>
    </div>

    <div class="cogstay-card">
        <div class="cogstay-card-body" style="text-align: center; padding: 30px 20px;">
            <p style="font-size: 13px; text-transform: uppercase; color: var(--color-text-muted); font-weight: 600; letter-spacing: 0.5px;">RevPAR</p>
            <h2 style="font-size: 36px; font-weight: 700; color: var(--color-primary-dark); margin: 10px 0;">₹12,466.00</h2>
            <span class="cogstay-badge success"><i class="fa-solid fa-arrow-trend-up"></i> +4.8% vs last month</span>
        </div>
    </div>
</div>

<!-- Downloadable reports options -->
<div class="cogstay-card">
    <div class="cogstay-card-header">
        <h3 class="cogstay-card-title"><i class="fa-solid fa-download"></i> Extract Operational Reports</h3>
    </div>
    <div class="cogstay-card-body">
        <div class="report-grid-options">
            <!-- Report 1 -->
            <div style="border: 1px solid var(--color-border); border-radius: var(--border-radius); padding: 20px; display: flex; flex-direction: column; align-items: flex-start;">
                <div style="font-size: 24px; color: var(--accent-admin); margin-bottom: 12px;"><i class="fa-solid fa-file-invoice-dollar"></i></div>
                <h4 style="font-size: 16px; font-weight: 600; color: var(--color-primary-dark); margin-bottom: 6px;">Daily Financial Ledger</h4>
                <p style="font-size: 12px; color: var(--color-text-muted); margin-bottom: 15px; line-height: 1.4;">Extracts room checkouts, extra charges, and payment gateway settlement summaries.</p>
                <button class="btn btn-secondary btn-sm" style="margin-top: auto;" onclick="showToast('Export Started', 'Generating PDF ledger report...', 'success')"><i class="fa-solid fa-file-pdf"></i> Export PDF</button>
            </div>

            <!-- Report 2 -->
            <div style="border: 1px solid var(--color-border); border-radius: var(--border-radius); padding: 20px; display: flex; flex-direction: column; align-items: flex-start;">
                <div style="font-size: 24px; color: var(--accent-admin); margin-bottom: 12px;"><i class="fa-solid fa-bed"></i></div>
                <h4 style="font-size: 16px; font-weight: 600; color: var(--color-primary-dark); margin-bottom: 6px;">Occupancy & Yield Log</h4>
                <p style="font-size: 12px; color: var(--color-text-muted); margin-bottom: 15px; line-height: 1.4;">Extracts stay ratios, average guest count, category bookings density summaries.</p>
                <button class="btn btn-secondary btn-sm" style="margin-top: auto;" onclick="showToast('Export Started', 'Generating Excel occupancy sheet...', 'success')"><i class="fa-solid fa-file-excel"></i> Export Excel</button>
            </div>

            <!-- Report 3 -->
            <div style="border: 1px solid var(--color-border); border-radius: var(--border-radius); padding: 20px; display: flex; flex-direction: column; align-items: flex-start;">
                <div style="font-size: 24px; color: var(--accent-admin); margin-bottom: 12px;"><i class="fa-solid fa-broom"></i></div>
                <h4 style="font-size: 16px; font-weight: 600; color: var(--color-primary-dark); margin-bottom: 6px;">Housekeeping Audits</h4>
                <p style="font-size: 12px; color: var(--color-text-muted); margin-bottom: 15px; line-height: 1.4;">Extracts average room cleaning times, housekeeper checklists, and cleanliness audits.</p>
                <button class="btn btn-secondary btn-sm" style="margin-top: auto;" onclick="showToast('Export Started', 'Generating CSV cleanliness log...', 'success')"><i class="fa-solid fa-file-csv"></i> Export CSV</button>
            </div>
        </div>
    </div>
</div>
