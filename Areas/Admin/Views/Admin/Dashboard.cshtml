@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "System Console";
    ViewData["Role"] = "Admin";
}

<div style="margin-bottom: 30px;">
    <h1 style="font-family: var(--font-serif); font-size: 32px; color: var(--color-primary-dark);">CogStay Administration Dashboard</h1>
    <p style="color: var(--color-text-muted);">Configure rooms, monitor reservations, extract analytics reports, and manage employee accounts.</p>
</div>

<!-- Stats Counter Grid -->
<div class="grid-container grid-cols-4" style="margin-bottom: 30px;">
    <div class="cogstay-stat-card admin">
        <div class="cogstay-stat-details">
            <p>Total Rooms</p>
            <h3>148 Rooms</h3>
        </div>
        <div class="cogstay-stat-icon">
            <i class="fa-solid fa-door-open" style="color: var(--accent-admin);"></i>
        </div>
    </div>

    <div class="cogstay-stat-card admin">
        <div class="cogstay-stat-details">
            <p>Active Staff</p>
            <h3>32 Users</h3>
        </div>
        <div class="cogstay-stat-icon">
            <i class="fa-solid fa-users" style="color: var(--accent-admin);"></i>
        </div>
    </div>

    <div class="cogstay-stat-card admin">
        <div class="cogstay-stat-details">
            <p>Today's Revenue</p>
            <h3>₹11,39,200</h3>
        </div>
        <div class="cogstay-stat-icon">
            <i class="fa-solid fa-money-bill-trend-up" style="color: var(--accent-admin);"></i>
        </div>
    </div>

    <div class="cogstay-stat-card admin">
        <div class="cogstay-stat-details">
            <p>System Health</p>
            <h3>99.98%</h3>
        </div>
        <div class="cogstay-stat-icon">
            <i class="fa-solid fa-server" style="color: var(--accent-admin);"></i>
        </div>
    </div>
</div>

<div class="booking-checkout-container">
    <!-- Left Column: Operations Overview & Active Logs -->
    <div>
        <div class="cogstay-card">
            <div class="cogstay-card-header">
                <h3 class="cogstay-card-title"><i class="fa-solid fa-bell"></i> Critical Operations Alerts</h3>
            </div>
            <div class="cogstay-card-body" style="display: flex; flex-direction: column; gap: 15px;">
                <div style="background-color: var(--color-warning-light); border-left: 4px solid var(--color-warning); padding: 15px; border-radius: 4px; display: flex; align-items: center; justify-content: space-between;">
                    <div>
                        <strong style="color: var(--color-warning); font-size: 14px;"><i class="fa-solid fa-triangle-exclamation"></i> Low Inventory Alert: Deluxe Suites</strong>
                        <p style="font-size: 12px; color: var(--color-text-muted); margin-top: 3px;">Only 2 Deluxe suites left for booking between June 28 - July 02.</p>
                    </div>
                    <a href="/Admin/Admin/RoomManagement" class="btn btn-secondary btn-sm" style="color: var(--color-warning); border-color: var(--color-warning); background-color: transparent;">Adjust Pricing</a>
                </div>

                <div style="background-color: var(--color-info-light); border-left: 4px solid var(--color-info); padding: 15px; border-radius: 4px; display: flex; align-items: center; justify-content: space-between;">
                    <div>
                        <strong style="color: var(--color-info); font-size: 14px;"><i class="fa-solid fa-envelope-open-text"></i> Pending Guest Feedbacks</strong>
                        <p style="font-size: 12px; color: var(--color-text-muted); margin-top: 3px;">5 new feedback reviews received today requiring manager review approvals.</p>
                    </div>
                    <a href="/Admin/Admin/ReservationMonitoring" class="btn btn-secondary btn-sm" style="color: var(--color-info); border-color: var(--color-info); background-color: transparent;">View Queue</a>
                </div>

                <div style="background-color: var(--color-success-light); border-left: 4px solid var(--color-success); padding: 15px; border-radius: 4px; display: flex; align-items: center; justify-content: space-between;">
                    <div>
                        <strong style="color: var(--color-success); font-size: 14px;"><i class="fa-solid fa-circle-check"></i> System Backup Completed</strong>
                        <p style="font-size: 12px; color: var(--color-text-muted); margin-top: 3px;">Global database daily backup successfully saved to cloud bucket at 02:00 AM.</p>
                    </div>
                    <a href="/Admin/Admin/Settings" class="btn btn-secondary btn-sm" style="color: var(--color-success); border-color: var(--color-success); background-color: transparent;">Backup Log</a>
                </div>
            </div>
        </div>

        <div class="cogstay-card">
            <div class="cogstay-card-header">
                <h3 class="cogstay-card-title"><i class="fa-solid fa-circle-nodes"></i> Recent System Access & Actions</h3>
            </div>
            <div class="cogstay-table-responsive">
                <table class="cogstay-table">
                    <thead>
                        <tr>
                            <th>Timestamp</th>
                            <th>Staff User</th>
                            <th>Role</th>
                            <th>Operation Done</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>10 mins ago</td>
                            <td>frontdesk_john</td>
                            <td>Front Desk</td>
                            <td>Checked In Guest: Room 102</td>
                            <td><span class="cogstay-badge success">Success</span></td>
                        </tr>
                        <tr>
                            <td>25 mins ago</td>
                            <td>housekeeping_mary</td>
                            <td>Housekeeper</td>
                            <td>Updated Room 304 to CLEAN</td>
                            <td><span class="cogstay-badge success">Success</span></td>
                        </tr>
                        <tr>
                            <td>1 hour ago</td>
                            <td>manager_robert</td>
                            <td>Manager</td>
                            <td>Exported Monthly Revenue Report</td>
                            <td><span class="cogstay-badge success">Success</span></td>
                        </tr>
                        <tr>
                            <td>2 hours ago</td>
                            <td>sysadmin</td>
                            <td>Admin</td>
                            <td>Modified Room 101 Rate to ₹11,600</td>
                            <td><span class="cogstay-badge success">Success</span></td>
                        </tr>
                        <tr>
                            <td>3 hours ago</td>
                            <td>frontdesk_sarah</td>
                            <td>Front Desk</td>
                            <td>Processed Check-out: Room 204</td>
                            <td><span class="cogstay-badge success">Success</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Right Column: Shortcuts & Quick Parameters -->
    <div>
        <div class="cogstay-card">
            <div class="cogstay-card-header">
                <h3 class="cogstay-card-title"><i class="fa-solid fa-sliders"></i> Configuration Tools</h3>
            </div>
            <div class="cogstay-card-body" style="display: flex; flex-direction: column; gap: 12px;">
                <a href="/Admin/Admin/RoomManagement" class="btn btn-secondary" style="width: 100%; text-align: left; justify-content: flex-start;">
                    <i class="fa-solid fa-door-closed" style="color: var(--accent-admin);"></i> Rooms Configuration
                </a>
                <a href="/Admin/Admin/ReservationMonitoring" class="btn btn-secondary" style="width: 100%; text-align: left; justify-content: flex-start;">
                    <i class="fa-solid fa-desktop" style="color: var(--accent-admin);"></i> Monitoring Panel
                </a>
                <a href="/Admin/Admin/Reports" class="btn btn-secondary" style="width: 100%; text-align: left; justify-content: flex-start;">
                    <i class="fa-solid fa-file-pdf" style="color: var(--accent-admin);"></i> Export Reports
                </a>
                <a href="/Admin/Admin/StaffUserManagement" class="btn btn-secondary" style="width: 100%; text-align: left; justify-content: flex-start;">
                    <i class="fa-solid fa-user-lock" style="color: var(--accent-admin);"></i> Employee Accounts
                </a>
                <a href="/Admin/Admin/Settings" class="btn btn-secondary" style="width: 100%; text-align: left; justify-content: flex-start;">
                    <i class="fa-solid fa-screwdriver-wrench" style="color: var(--accent-admin);"></i> System Settings
                </a>
            </div>
        </div>
    </div>
</div>
